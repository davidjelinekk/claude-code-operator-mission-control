PORT=3001
OPERATOR_TOKEN=your-secret-token
DATABASE_URL=postgresql://operator:operator@localhost:5434/cc_operator
REDIS_URL=redis://127.0.0.1:6379/2
CLAUDE_HOME=~/.claude
ANTHROPIC_API_KEY=
NODE_ENV=development

# First-run admin user (only used if no users exist in database)
AUTH_USER=admin
AUTH_PASS=changeme

# Embedding provider for semantic search (requires Ollama: brew install ollama && ollama pull nomic-embed-text)
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
